# =============================================================================
# TrulyIAS Multi-Agent Scheduling Assistant — Environment Variables
# =============================================================================
# NEVER commit this file with real values. Copy to .env and fill in secrets.
# =============================================================================

# ── LLM API Configuration ───────────────────────────────────────────────────
# Groq API Key (free tier, 500 tok/s) — get from https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OR use OpenAI (uncomment if preferred)
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── App Configuration ───────────────────────────────────────────────────────
APP_TITLE=TrulyIAS Scheduling Assistant
APP_ICON=📅
DEBUG=false

# ── Webhook for Mock Notifications ──────────────────────────────────────────
# Get a free URL from https://webhook.site/ — paste your unique URL here
WEBHOOK_URL=https://webhook.site/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Database Paths (relative to project root) ───────────────────────────────
# These are file paths, not connection strings. They auto-create on first run.
# You do NOT need to change these unless you want a different location.
DB_PATH=data/appointments.db
CHECKPOINT_DB=data/checkpoints.db
